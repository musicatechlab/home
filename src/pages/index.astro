---
import Layout from '../layouts/Layout.astro';
import AdSense from '../components/AdSense.astro';

// プロジェクト一覧（カスタムドメイン移行後は URL を差し替える → docs/ARCHITECTURE.md）
const projects = [
  {
    no: '01',
    title: 'MIDI to Part MP3',
    description: '合唱練習用のパート別強調音源を、MIDI からブラウザだけで生成',
    url: 'https://midiconverter.musicatechlab.com',
    status: null
  },
  {
    no: '02',
    title: 'Harmodus Piano',
    description: '響きを調律するピアノアプリ — 公式サイト',
    url: 'https://harmoduspiano.musicatechlab.com/',
    status: null
  },
  {
    no: '03',
    title: 'Blog',
    description: '開発記録と、音楽×技術のノート',
    url: 'https://blog.musicatechlab.com',
    status: null
  },
  {
    no: '04',
    title: 'Dictio',
    description: '音楽用語辞典',
    url: null,
    status: 'In preparation'
  },
  {
    no: '05',
    title: 'Portfolio',
    description: '制作物と実績',
    url: null,
    status: 'In preparation'
  }
];
---

<Layout title="MusicaTechLab — Where music meets technology">
  <main class="page">
    <header class="hero">
      <p class="overline">Musica Tech Lab</p>
      <h1 class="headline">音楽と技術のあいだに、<em>余白</em>を。</h1>
      <p class="tagline">Where music meets technology.</p>
    </header>

    <div class="mtl-staff" role="presentation"></div>

    <section class="programme" aria-label="Projects">
      <h2 class="programme-label">Programme</h2>
      <ol class="programme-list">
        {projects.map(p => (
          <li>
            {p.url ? (
              <a class="row" href={p.url}>
                <span class="row-no">{p.no}</span>
                <span class="row-body">
                  <span class="row-title">{p.title}</span>
                  <span class="row-desc">{p.description}</span>
                </span>
                <span class="row-arrow" aria-hidden="true">→</span>
              </a>
            ) : (
              <div class="row is-pending">
                <span class="row-no">{p.no}</span>
                <span class="row-body">
                  <span class="row-title">{p.title}</span>
                  <span class="row-desc">{p.description}</span>
                </span>
                <span class="row-status">{p.status}</span>
              </div>
            )}
          </li>
        ))}
      </ol>
    </section>

    <AdSense />
  </main>

  <footer class="footer">
    <p>&copy; {new Date().getFullYear()} MusicaTechLab</p>
  </footer>
</Layout>

<style>
  .page {
    width: min(100% - var(--mtl-space-6), 720px);
    margin-inline: auto;
    flex: 1;
  }

  .hero {
    padding: clamp(var(--mtl-space-8), 16vh, 160px) 0 var(--mtl-space-8);
  }

  .overline {
    font-size: var(--mtl-text-pp);
    font-weight: 600;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--mtl-ink-3);
    margin-bottom: var(--mtl-space-3);
  }

  .headline {
    font-family: var(--mtl-font-serif);
    font-weight: 400;
    font-size: clamp(var(--mtl-text-ff), 5.2vw, var(--mtl-text-tutti));
    line-height: 1.3;
    letter-spacing: 0.02em;
    margin-bottom: var(--mtl-space-2);
  }

  .headline em {
    font-style: normal;
    color: var(--mtl-accent);
  }

  .tagline {
    font-family: var(--mtl-font-serif);
    font-size: var(--mtl-text-mf);
    color: var(--mtl-ink-2);
    letter-spacing: 0.04em;
  }

  .programme {
    padding: var(--mtl-space-8) 0 var(--mtl-space-6);
  }

  .programme-label {
    font-size: var(--mtl-text-pp);
    font-weight: 600;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--mtl-ink-3);
    margin-bottom: var(--mtl-space-3);
  }

  .programme-list {
    list-style: none;
    border-top: 1px solid var(--mtl-line);
  }

  .row {
    display: flex;
    align-items: baseline;
    gap: var(--mtl-space-3);
    padding: var(--mtl-space-3) var(--mtl-space-1);
    border-bottom: 1px solid var(--mtl-line);
    text-decoration: none;
    transition:
      background-color var(--mtl-dur-s) var(--mtl-ease),
      padding-left var(--mtl-dur-m) var(--mtl-ease);
  }

  a.row:hover {
    background: var(--mtl-paper-dim);
    padding-left: var(--mtl-space-2);
  }

  .row-no {
    font-family: var(--mtl-font-serif);
    font-size: var(--mtl-text-p);
    color: var(--mtl-ink-3);
    min-width: 2ch;
  }

  .row-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .row-title {
    font-weight: 600;
    font-size: var(--mtl-text-mf);
    letter-spacing: 0.02em;
    transition: color var(--mtl-dur-s) var(--mtl-ease);
  }

  a.row:hover .row-title {
    color: var(--mtl-accent);
  }

  .row-desc {
    font-size: var(--mtl-text-p);
    color: var(--mtl-ink-2);
  }

  .row-arrow {
    color: var(--mtl-ink-3);
    opacity: 0;
    transform: translateX(-6px);
    transition:
      opacity var(--mtl-dur-s) var(--mtl-ease),
      transform var(--mtl-dur-m) var(--mtl-ease);
  }

  a.row:hover .row-arrow {
    opacity: 1;
    transform: translateX(0);
    color: var(--mtl-accent);
  }

  .is-pending .row-title,
  .is-pending .row-desc {
    color: var(--mtl-ink-3);
  }

  .row-status {
    font-size: var(--mtl-text-pp);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--mtl-ink-3);
    border: 1px solid var(--mtl-line);
    border-radius: var(--mtl-radius);
    padding: 2px 10px;
    white-space: nowrap;
  }

  .footer {
    border-top: 1px solid var(--mtl-line);
    margin-top: var(--mtl-space-8);
    padding: var(--mtl-space-4);
    text-align: center;
    font-size: var(--mtl-text-p);
    color: var(--mtl-ink-3);
  }

  @media (max-width: 560px) {
    .row {
      gap: var(--mtl-space-2);
    }
    .row-arrow,
    .row-status {
      display: none;
    }
  }
</style>
