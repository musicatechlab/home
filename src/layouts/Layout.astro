---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'MusicaTechLab — Where music meets technology. 音楽と技術のあいだに、余白を。' } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600&family=Zen+Kaku+Gothic+New:wght@400;500;700&family=Bodoni+Moda:opsz,wght@6..96,400&family=Shippori+Mincho:wght@400;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  /* MusicaTechLab Design Tokens — "Score"
     正: リポジトリルート design/tokens.css（変更時は同期すること） */
  :root {
    --mtl-paper: #fbfbf9;
    --mtl-paper-dim: #f3f3ef;
    --mtl-ink: #1a1a1a;
    --mtl-ink-2: #4a4a48;
    --mtl-ink-3: #8b8b87;
    --mtl-line: #dcdcd6;
    --mtl-line-soft: #eaeae5;
    --mtl-accent: #a93b2a;
    --mtl-accent-deep: #8a2f21;

    --mtl-font-sans: 'Montserrat', 'Zen Kaku Gothic New', 'Hiragino Kaku Gothic ProN', sans-serif;
    --mtl-font-serif: 'Bodoni Moda', 'Shippori Mincho', 'Hiragino Mincho ProN', serif;

    --mtl-text-pp: 0.75rem;
    --mtl-text-p: 0.875rem;
    --mtl-text-mp: 1rem;
    --mtl-text-mf: 1.25rem;
    --mtl-text-f: 1.5625rem;
    --mtl-text-ff: 2rem;
    --mtl-text-fff: 2.5rem;
    --mtl-text-tutti: 3.25rem;

    --mtl-space-1: 8px;
    --mtl-space-2: 16px;
    --mtl-space-3: 24px;
    --mtl-space-4: 32px;
    --mtl-space-6: 48px;
    --mtl-space-8: 64px;
    --mtl-space-12: 96px;

    --mtl-container: 1120px;
    --mtl-radius: 2px;
    --mtl-dur-s: 160ms;
    --mtl-dur-m: 240ms;
    --mtl-ease: cubic-bezier(0.2, 0, 0, 1);
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    background: var(--mtl-paper);
    color: var(--mtl-ink);
    font-family: var(--mtl-font-sans);
    line-height: 1.8;
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    font-size: var(--mtl-text-mp);
    -webkit-font-smoothing: antialiased;
  }

  ::selection {
    background: var(--mtl-ink);
    color: var(--mtl-paper);
  }

  a {
    color: inherit;
  }

  .mtl-staff {
    height: 17px;
    background: repeating-linear-gradient(
      to bottom,
      var(--mtl-line) 0,
      var(--mtl-line) 1px,
      transparent 1px,
      transparent 4px
    );
    border: none;
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
